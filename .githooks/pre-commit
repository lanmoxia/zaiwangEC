#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if command -v pwsh >/dev/null 2>&1; then
  PS=pwsh
elif command -v powershell >/dev/null 2>&1; then
  PS=powershell
else
  echo "PowerShell is required for governance hooks."
  exit 1
fi

"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/check-task-state.ps1 -Mode Commit -AllowDirty
"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/check-forbidden-paths.ps1 -Staged
